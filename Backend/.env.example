# ── Database ──────────────────────────────────────────────────────────────────
# Set USE_DEMO_DB=true for local SQLite dev, false for production PostgreSQL
USE_DEMO_DB=true

DB_NAME=voting_system
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
# DB_PORT=5432  # optional, defaults to 5432

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development   # set to "production" in prod

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:5173

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
VOTE_SECRET=replace_with_another_long_random_secret

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Email (Brevo / Sendinblue) ────────────────────────────────────────────────
EMAIL_USER=your_email@example.com
BREVO_API_KEY=your_brevo_api_key

# ── AI / External APIs ────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
PANDASCORE_API_KEY=your_pandascore_api_key

# ── Clerk (optional – only if using Clerk SDK on backend) ─────────────────────
CLERK_SECRET_KEY=sk_live_your_clerk_secret
